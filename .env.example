# --- Supabase (client-safe, already in use) ---
SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Supabase service role (SERVER ONLY — never prefix with VITE_) ---
# Project Settings > API > service_role key. Bypasses RLS; used only by
# /api/stripe/webhook to write billing data on a user's behalf.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Stripe (SERVER ONLY) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# https://dashboard.stripe.com/webhooks -> your endpoint -> "Signing secret"
STRIPE_WEBHOOK_SECRET=""
# https://dashboard.stripe.com/products -> your VIP product -> Price IDs
STRIPE_PRICE_VIP_MONTHLY=""
STRIPE_PRICE_VIP_YEARLY=""

# --- App ---
# Public base URL used to build Stripe success/cancel/return URLs.
APP_URL="http://localhost:3000"

# --- PayPal (SERVER ONLY) ---
# https://developer.paypal.com/dashboard/applications
PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# https://developer.paypal.com/dashboard/webhooks -> your webhook -> ID
PAYPAL_WEBHOOK_ID=""
# https://developer.paypal.com/dashboard -> Product Catalog -> your VIP plans
PAYPAL_PLAN_VIP_MONTHLY=""
PAYPAL_PLAN_VIP_YEARLY=""
PAYPAL_ONE_TIME_PRICE_USD="19.99"

# --- Streaming worker (Render Background Worker / docker-compose) ---
REDIS_URL="redis://localhost:6379"
